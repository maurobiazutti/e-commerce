
<div class="max-w-md mx-auto mt-24 bg-white p-8 rounded-xl shadow-lg">
  <h2 class="text-2xl font-semibold text-center mb-6 text-gray-800">Log in</h2>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    <div class="mb-4">
      <%= f.label :email, class: "block text-gray-700 font-medium mb-1" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div class="mb-4">
      <%= f.label :password, class: "block text-gray-700 font-medium mb-1" %>
      <%= f.password_field :password, autocomplete: "current-password", class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="mb-4 flex items-center">
        <%= f.check_box :remember_me, class: "mr-2" %>
        <%= f.label :remember_me, class: "text-gray-700" %>
      </div>
    <% end %>

    <div class="mt-6">
      <%= f.submit "Log in", class: "w-full bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg transition duration-200" %>
    </div>
  <% end %>

  <div class="my-4 text-center text-gray-500">ou</div>

    <!-- <%= button_to 'Login with Google', user_google_oauth2_omniauth_authorize_path, method: :post, :data => {turbo: "false"} %> -->
    <!-- <%= button_to "Entrar com Google", user_google_oauth2_omniauth_authorize_path, data: { turbo: false } %> -->
    <!-- <%= link_to "Entrar com Google", user_google_oauth2_omniauth_authorize_path, method: :post, data: { turbo: false }, class: "your-button-class" %> -->
  <div class="mt-4 text-center text-sm text-gray-600">
    <%= render "devise/shared/links" %>
  </div>
</div> 
  
